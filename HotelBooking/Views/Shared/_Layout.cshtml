<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Booking Cochabamba</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                <i class="fas fa-hotel me-2 text-warning"></i>Hotel Booking
                <span class="text-warning">Cochabamba</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Inicio
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @if (Context.Session.GetString("UsuarioId") != null)
                    {
                        var rol = Context.Session.GetString("UsuarioRol");
                        var nombre = Context.Session.GetString("UsuarioNombre");
                        if (rol == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="fas fa-tachometer-alt me-1"></i>Panel Admin
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>@nombre
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (rol == "Cliente")
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Cliente" asp-action="MisReservas">
                                            <i class="fas fa-calendar-check me-2"></i>Mis Reservas
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Cliente" asp-action="Perfil">
                                            <i class="fas fa-user-edit me-2"></i>Mi Perfil
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">
                                        <i class="fas fa-sign-out-alt me-2"></i>Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Iniciar Sesión
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning ms-2 px-3" asp-controller="Auth" asp-action="Registro">
                                <i class="fas fa-user-plus me-1"></i>Registrarse
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- ALERTAS GLOBALES -->
    <div class="container mt-3">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle me-2"></i>@TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <!-- CONTENIDO PRINCIPAL -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="mt-5 py-4" style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #aaa;">
        <div class="container text-center">
            <p class="mb-1">
                <i class="fas fa-hotel text-warning me-2"></i>
                <strong class="text-white">Hotel Booking Cochabamba</strong>
            </p>
            <p class="mb-0 small">📍 Av. Heroínas #123, Cochabamba, Bolivia</p>
            <p class="mb-0 small">📞 +591 4 4123456 | ✉️ info@hotelbooking.com</p>
            <hr style="border-color: #333;">
            <p class="mb-0 small">© 2024 Hotel Booking Cochabamba - Proyecto Final Estructura de Datos</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
