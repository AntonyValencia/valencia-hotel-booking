@model HotelBooking.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Panel Administrador";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- TARJETAS DE ESTADÍSTICAS -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-bed fa-2x text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalHabitaciones</div>
                    <div class="text-muted small">Habitaciones activas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-calendar-check fa-2x text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.TotalReservas</div>
                    <div class="text-muted small">Total reservas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-clock fa-2x text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@Model.ReservasPendientes</div>
                    <div class="text-muted small">Pendientes</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="icon-box bg-info bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-dollar-sign fa-2x text-info"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">Bs. @Model.IngresosMes.ToString("N0")</div>
                    <div class="text-muted small">Ingresos este mes</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ACCIONES RÁPIDAS -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <h5 class="fw-bold mb-3"><i class="fas fa-bolt me-2 text-warning"></i>Acciones rápidas</h5>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="CrearHabitacion" class="btn btn-primary w-100 py-3">
            <i class="fas fa-plus-circle fa-2x d-block mb-1"></i>
            <small>Nueva Habitación</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Habitaciones" class="btn btn-outline-primary w-100 py-3">
            <i class="fas fa-bed fa-2x d-block mb-1"></i>
            <small>Ver Habitaciones</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Reservas" class="btn btn-outline-success w-100 py-3">
            <i class="fas fa-list-alt fa-2x d-block mb-1"></i>
            <small>Ver Reservas</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Reservas" asp-route-estado="Pendiente" class="btn btn-outline-warning w-100 py-3">
            <i class="fas fa-exclamation-circle fa-2x d-block mb-1"></i>
            <small>Pendientes (@Model.ReservasPendientes)</small>
        </a>
    </div>
</div>

<!-- ÚLTIMAS RESERVAS -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2 text-primary"></i>Últimas reservas</h5>
        <a asp-action="Reservas" class="btn btn-sm btn-outline-primary">Ver todas</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th>Habitación</th>
                        <th>Fechas</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.UltimasReservas)
                    {
                        var badgeColor = r.Estado switch
                        {
                            "Pendiente" => "warning",
                            "Confirmada" => "success",
                            "CheckIn" => "info",
                            "CheckOut" => "dark",
                            "Cancelada" => "danger",
                            _ => "secondary"
                        };
                        <tr>
                            <td><small class="text-muted">#@r.Id</small></td>
                            <td>
                                <strong>@r.Usuario?.Nombre</strong><br />
                                <small class="text-muted">@r.Usuario?.Email</small>
                            </td>
                            <td><small>@r.Habitacion?.Nombre</small></td>
                            <td>
                                <small>@r.FechaEntrada.ToString("dd/MM/yy") → @r.FechaSalida.ToString("dd/MM/yy")</small>
                            </td>
                            <td><strong>Bs. @r.TotalPagar.ToString("N0")</strong></td>
                            <td><span class="badge bg-@badgeColor">@r.Estado</span></td>
                            <td>
                                @if (r.Estado == "Pendiente")
                                {
                                    <form asp-action="CambiarEstadoReserva" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <input type="hidden" name="nuevoEstado" value="Confirmada" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
