@model HotelBooking.Models.Habitacion
@{
    ViewData["Title"] = "Editar Habitación";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <form asp-action="EditarHabitacion" asp-route-id="@Model.Id"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Nombre" class="form-label fw-bold">Nombre de la habitación</label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoriaId" class="form-label fw-bold">Categoría</label>
                            <select asp-for="CategoriaId" asp-items="ViewBag.Categorias" class="form-select"></select>
                            <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PrecioPorNoche" class="form-label fw-bold">Precio por noche (Bs.)</label>
                            <input asp-for="PrecioPorNoche" type="number" class="form-control" min="1" step="0.01" />
                            <span asp-validation-for="PrecioPorNoche" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Capacidad" class="form-label fw-bold">Capacidad</label>
                            <input asp-for="Capacidad" type="number" class="form-control" min="1" max="20" />
                            <span asp-validation-for="Capacidad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Estado</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="Disponible" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="Disponible" class="form-check-label">Disponible</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Servicios" class="form-label fw-bold">Servicios (separados por coma)</label>
                            <input asp-for="Servicios" class="form-control" />
                        </div>

                        <!-- Imágenes actuales -->
                        @if (Model.Imagenes.Any())
                        {
                            <div class="col-12">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-images me-1 text-primary"></i>Imágenes actuales
                                </label>
                                <div class="d-flex gap-3 flex-wrap">
                                    @foreach (var img in Model.Imagenes)
                                    {
                                        <div class="position-relative">
                                            <img src="@img.UrlImagen" class="rounded-3"
                                                 style="width:120px;height:80px;object-fit:cover;" />
                                            @if (img.EsPrincipal)
                                            {
                                                <span class="badge bg-primary position-absolute top-0 start-0"
                                                      style="font-size:0.6rem">Principal</span>
                                            }
                                            <form asp-action="EliminarImagen" method="post"
                                                  onsubmit="return confirm('¿Eliminar esta imagen?')"
                                                  class="position-absolute top-0 end-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imagenId" value="@img.Id" />
                                                <input type="hidden" name="habitacionId" value="@Model.Id" />
                                                <button type="submit"
                                                        class="btn btn-danger btn-sm p-0 px-1"
                                                        style="font-size:0.7rem; line-height:1.5;">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Agregar nuevas imágenes -->
                        <div class="col-12">
                            <label class="form-label fw-bold">
                                <i class="fas fa-plus me-1 text-success"></i>Agregar nuevas imágenes
                            </label>
                            <input type="file" name="nuevasImagenes" class="form-control"
                                   accept="image/*" multiple id="inputNuevasImagenes" />
                            <div id="previewNuevas" class="d-flex gap-2 mt-2 flex-wrap"></div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <a asp-action="Habitaciones" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-arrow-left me-2"></i>Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="fas fa-save me-2"></i>Guardar cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('inputNuevasImagenes')?.addEventListener('change', function() {
            const preview = document.getElementById('previewNuevas');
            preview.innerHTML = '';
            [...this.files].forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'rounded-3';
                    img.style = 'width:100px;height:70px;object-fit:cover;';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}
