@* =====================================================
   Views/Auth/Login.cshtml
   ===================================================== *@
@model HotelBooking.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center py-5"
     style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5">
                        <!-- Logo -->
                        <div class="text-center mb-4">
                            <i class="fas fa-hotel fa-3x text-primary mb-3"></i>
                            <h3 class="fw-bold">Bienvenido de nuevo</h3>
                            <p class="text-muted">Inicia sesión en tu cuenta</p>
                        </div>

                        <form asp-controller="Auth" asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="alert alert-danger d-none" id="erroresLogin"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label fw-bold">
                                    <i class="fas fa-envelope me-1 text-primary"></i>Email
                                </label>
                                <input asp-for="Email" class="form-control form-control-lg"
                                       placeholder="usuario@gmail.com" autocomplete="email" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-bold">
                                    <i class="fas fa-lock me-1 text-primary"></i>Contraseña
                                </label>
                                <div class="input-group">
                                    <input asp-for="Password" class="form-control form-control-lg"
                                           placeholder="Tu contraseña" id="inputPassword" autocomplete="current-password" />
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePassword('inputPassword', this)">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4 form-check">
                                <input asp-for="Recordarme" class="form-check-input" type="checkbox" />
                                <label asp-for="Recordarme" class="form-check-label">Recordarme</label>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                                <i class="fas fa-sign-in-alt me-2"></i>Iniciar Sesión
                            </button>
                        </form>

                        <hr />
                        <div class="text-center">
                            <p class="mb-0">
                                ¿No tienes cuenta?
                                <a asp-controller="Auth" asp-action="Registro" class="text-primary fw-bold">
                                    Regístrate aquí
                                </a>
                            </p>
                        </div>

                        <!-- Credenciales de prueba -->
                        <div class="mt-3 p-3 bg-light rounded-3">
                            <p class="mb-1 small fw-bold text-muted">
                                <i class="fas fa-info-circle me-1"></i>Cuenta de prueba:
                            </p>
                            <p class="mb-0 small text-muted">Admin: admin@hotelbooking.com / Admin123!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
        // Mostrar errores de validación
        const errores = document.querySelector('.validation-summary-errors');
        if (errores) document.getElementById('erroresLogin').classList.remove('d-none');
    </script>
}
