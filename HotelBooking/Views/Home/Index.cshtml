@model List<HotelBooking.Models.Habitacion>
@{
    ViewData["Title"] = "Inicio";
}

<!-- HERO con video de fondo en loop -->
<section class="hero-video-section">
    <video autoplay muted loop playsinline class="hero-video"
           poster="https://images.pexels.com/photos/271624/pexels-photo-271624.jpeg">
        <source src="https://videos.pexels.com/video-files/3773486/3773486-hd_1920_1080_30fps.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="container hero-content-wrap">
        <h1 class="hero-title">HOTEL BOOKING<br><span>COCHABAMBA</span></h1>
        <p class="hero-subtitle">Experiencia de hotel 5 estrellas en el corazón de Bolivia</p>
        <div class="d-flex gap-3 mt-4 flex-wrap">
            <div class="hero-stat"><div class="num">@Model.Count</div><div class="lab">Habitaciones</div></div>
            <div class="hero-stat"><div class="num">4</div><div class="lab">Categorías</div></div>
            <div class="hero-stat"><div class="num">★ 5.0</div><div class="lab">Calificación</div></div>
        </div>
    </div>
</section>

<!-- FILTROS -->
<section class="py-4 bg-light border-bottom">
    <div class="container">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="busqueda" class="form-control" placeholder="Buscar habitación..."
                           value="@ViewBag.Busqueda" />
                </div>
            </div>
            <div class="col-md-4">
                <select name="categoriaId" class="form-select">
                    <option value="">Todas las categorías</option>
                    @foreach (var cat in (List<HotelBooking.Models.Categoria>)ViewBag.Categorias)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.CategoriaSeleccionada?.ToString() == cat.Id.ToString())">
                            @cat.Nombre
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="fas fa-filter me-1"></i>Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </div>
        </form>
        <!-- Filtros rápidos por categoría -->
        <div class="d-flex gap-2 mt-3 flex-wrap">
            <a asp-action="Index" class="badge rounded-pill text-decoration-none fs-6 @(ViewBag.CategoriaSeleccionada == null ? "bg-primary" : "bg-secondary")">
                Todas
            </a>
            @foreach (var cat in (List<HotelBooking.Models.Categoria>)ViewBag.Categorias)
            {
                <a asp-action="Index" asp-route-categoriaId="@cat.Id"
                   class="badge rounded-pill text-decoration-none fs-6 @(ViewBag.CategoriaSeleccionada?.ToString() == cat.Id.ToString() ? "bg-primary" : "bg-secondary")">
                    @cat.Nombre
                </a>
            }
        </div>
    </div>
</section>

<!-- HABITACIONES -->
<section class="py-5">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">No se encontraron habitaciones</h4>
                <a asp-action="Index" class="btn btn-primary mt-2">Ver todas las habitaciones</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var hab in Model)
                {
                    var imagenPrincipal = hab.Imagenes.FirstOrDefault(i => i.EsPrincipal)?.UrlImagen
                    ?? hab.Imagenes.FirstOrDefault()?.UrlImagen
                    ?? "/images/default-room.jpg";
                    <div class="col-sm-6 col-lg-4">
                        <div class="card room-card h-100 border-0 shadow-sm">
                            <!-- Imagen con efectos hover -->
                            <div class="room-img-container">
                                <img src="@imagenPrincipal" class="room-img" alt="@hab.Nombre" />
                                <div class="room-overlay">
                                    <a asp-controller="Home" asp-action="Detalle" asp-route-id="@hab.Id"
                                       class="btn btn-light btn-sm me-2">
                                        <i class="fas fa-eye me-1"></i>Ver Detalle
                                    </a>
                                    <a asp-controller="Reserva" asp-action="Crear" asp-route-habitacionId="@hab.Id"
                                       class="btn btn-warning btn-sm">
                                        <i class="fas fa-calendar-plus me-1"></i>Reservar
                                    </a>
                                </div>
                                <span class="badge bg-primary room-badge">@hab.Categoria?.Nombre</span>
                                @if (hab.Imagenes.Count > 1)
                                {
                                    <span class="badge bg-dark room-badge-count">
                                        <i class="fas fa-images me-1"></i>@hab.Imagenes.Count fotos
                                    </span>
                                }
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold mb-1">@hab.Nombre</h5>
                                <p class="text-muted small mb-2">
                                    <i class="fas fa-users me-1"></i>Hasta @hab.Capacidad personas
                                </p>
                                <p class="card-text text-muted small flex-grow-1">@hab.Descripcion</p>
                                @if (!string.IsNullOrEmpty(hab.Servicios))
                                {
                                    <div class="mb-2">
                                        @foreach (var servicio in hab.Servicios.Split(',').Take(3))
                                        {
                                            <span class="badge bg-light text-dark border me-1 mb-1 small">@servicio.Trim()</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <span class="fs-5 fw-bold text-primary">Bs. @hab.PrecioPorNoche.ToString("N0")</span>
                                    <span class="text-muted small">/noche</span>
                                </div>
                                <a asp-controller="Reserva" asp-action="Crear" asp-route-habitacionId="@hab.Id"
                                   class="btn btn-primary btn-sm px-3">
                                    <i class="fas fa-calendar-plus me-1"></i>Reservar
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@section Styles {
    <style>
        .room-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-radius: 16px;
            overflow: hidden;
        }

            .room-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
            }

        .room-img-container {
            position: relative;
            overflow: hidden;
            height: 220px;
        }

        .room-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .room-card:hover .room-img {
            transform: scale(1.08);
        }

        .room-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .room-card:hover .room-overlay {
            opacity: 1;
        }

        .room-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            font-size: 0.75rem;
        }

        .room-badge-count {
            position: absolute;
            bottom: 12px;
            right: 12px;
            font-size: 0.7rem;
        }

        .hero-section {
            position: relative;
        }

        .hero-stat {
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .hero-video-section {
            position: relative;
            height: 520px;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .hero-video {
            position: absolute;
            top: 50%;
            left: 50%;
            min-width: 100%;
            min-height: 100%;
            transform: translate(-50%, -50%);
            object-fit: cover;
            z-index: 0;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0,0,0,.85) 0%, rgba(0,0,0,.6) 60%, rgba(0,0,0,.4) 100%);
            z-index: 1;
        }

        .hero-content-wrap {
            position: relative;
            z-index: 2;
        }

        .hero-title {
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.15;
        }

            .hero-title span {
                color: #C9A84C;
            }

        .hero-subtitle {
            color: #ccc;
            font-size: 1.15rem;
            max-width: 520px;
            margin-top: 12px;
        }

        .hero-stat {
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.15);
            backdrop-filter: blur(8px);
            border-radius: 12px;
            padding: 14px 26px;
            text-align: center;
        }

            .hero-stat .num {
                font-size: 1.7rem;
                font-weight: 800;
                color: #C9A84C;
            }

            .hero-stat .lab {
                font-size: .75rem;
                color: #ccc;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

        .hero-video-section {
            position: relative;
            height: 520px;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .hero-video {
            position: absolute;
            top: 50%;
            left: 50%;
            min-width: 100%;
            min-height: 100%;
            width: auto;
            height: auto;
            transform: translate(-50%, -50%);
            object-fit: cover;
            z-index: 0;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(0,0,0,.85) 0%, rgba(0,0,0,.6) 60%, rgba(0,0,0,.4) 100%);
            z-index: 1;
        }

        .hero-content-wrap {
            position: relative;
            z-index: 2;
        }

        .hero-title {
            font-size: 3rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.15;
        }

            .hero-title span {
                color: #C9A84C;
            }

        .hero-subtitle {
            color: #ccc;
            font-size: 1.15rem;
            max-width: 520px;
            margin-top: 12px;
        }

        .hero-stat {
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.15);
            backdrop-filter: blur(8px);
            border-radius: 12px;
            padding: 14px 26px;
            text-align: center;
        }

            .hero-stat .num {
                font-size: 1.7rem;
                font-weight: 800;
                color: #C9A84C;
            }

            .hero-stat .lab {
                font-size: .75rem;
                color: #ccc;
                text-transform: uppercase;
                letter-spacing: 1px;
            }
    </style>
}
